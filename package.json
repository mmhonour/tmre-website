{
  "name": "tmre-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "build:netlify": "node scripts/rebuild-native-modules.cjs && tsx --require ./scripts/stub-server-only.cjs scripts/prepare-netlify-bundle.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "discover:rets": "node --env-file=.env.local node_modules/.bin/tsx scripts/discover-rets.ts",
    "sync:listings": "tsx --require ./scripts/stub-server-only.cjs scripts/sync-listings.ts",
    "sync:property-addresses": "tsx --require ./scripts/stub-server-only.cjs scripts/sync-property-addresses.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "node-expat": "^2.4.1",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.0",
    "rets-client": "^5.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@netlify/functions": "^5.3.0",
    "@netlify/plugin-nextjs": "^5.15.12",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
